--sumarFold: suma amb foldl
sumarFold :: Num a => [a] -> a
sumarFold = foldl (+) 0 --Suma tots els elements de l'array d'esquerra a dreta començant per un 0

--multiplicarFold: multiplica amb foldl
multiplicarFold :: Num a => [a] -> a
multiplicarFold = foldl (*) 1 --Multiplica tots els elements de l'array, d'esquerra a dreta començant per un 1

