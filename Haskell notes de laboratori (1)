--sumarQuadrats: suma dels quadrats dels elements
sumarQuadrats :: Num a => [a] -> a
sumarQuadrats [] = 0
sumarQuadrats (x:xs) = x*x + sumarQuadrats xs

--esborrarDuplicats: elimina elements repetits d'una llista
esborrarDuplicats :: [Int] -> [Int]
esborrarDuplicats [] = []
esborrarDuplicats (x:xs)
  | x `elem` xs = esborrarDuplicats xs --Si x ja està en xs, fem funció amb xs (elem és una funció haskell que retornà un booleà de si és o no dins la llista)
  | otherwise   = x : esborrarDuplicats xs --Si x no està en rest, l'afegim al capdavant i fem funció en xs

--esPalindrom1: comprova si una llista és palíndrom (mode amb reverse)
--mode 1
esPalindrom1 :: Eq a => [a] -> Bool --El tipus a ha de poder comparar-se. Entra un array, surt un booleà
esPalindrom1 xs = xs == reverse xs --Aquí compara xs amb el revers de xs per veure si és palíndrom

--esPalindrom2: comprova si una llista és palíndrom (mode recursiu)
--mode 2
esPalindrom2 :: Eq a => [a] -> Bool
esPalindrom2 [] = True
esPalindrom2 [_] = True
esPalindrom2 xs =
  head xs == last xs && esPalindrom2 (init (tail xs)) --Compara el primer valor i l'últim, fa la funció recursiva sense el primer i últim valor
  
--partirLlista: divideix una llista en dues parts segons un índex n
partirLlista :: Int -> [a] -> ([a],[a]) --Rep un enter n i una llista, retorna una tupla amb dues llistes
partirLlista n xs = (myTake n xs, myDrop n xs) --La primera part són els n primers elements (myTake), i la segona part és la resta de la llista (myDrop)

--rotarLlista: rota una llista n posicions cap a l’esquerra
rotarLlista :: Int -> [a] -> [a]
rotarLlista _ [] = [] --Si la llista és buida, retornem llista buida independentment del nombre n
rotarLlista n xs = myDrop k xs ++ myTake k xs --Usem myDrop per eliminar els k primers nombres i myTake per afegir seguidament els k primers nombres
  where
    k = n `mod` myLength xs --Si n és més gran que el nombre de valors de la llista, ajustem aquest valor amb el mòdul

--filtrarParells: retorna només els nombres parells d’una llista d'enters
filtrarParells :: [Int] -> [Int]
filtrarParells [] = []
filtrarParells (x:xs)
  | even x = x : filtrarParells xs --Si x és parell, l'afegim al resultat i continuem analitzant recursivament. even és una funció que mira si són parells
  | otherwise = filtrarParells xs --Si no ho és, no l'afegim i continuem analitzant recursivament
  
