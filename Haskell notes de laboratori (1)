--doblar: dobla cada element d’una llista
doblar :: Num a => [a] -> [a] --Restricció de tipus nombre (Int, integer, double, float)
doblar [] = []
doblar (x:xs) = (2*x) : doblar xs

--incrementar: suma 1 a cada element
incrementar :: Num a => [a] -> [a]
incrementar [] = []
incrementar (x:xs) = (x+1) : incrementar xs

--sumar: suma tots els elements
sumar :: Num a => [a] -> a
sumar [] = 0
sumar (x:xs) = x + sumar xs

--multiplicar: multiplica tots els elements
multiplicar :: Num a => [a] -> a
multiplicar [] = 1
multiplicar (x:xs) = x * multiplicar xs

