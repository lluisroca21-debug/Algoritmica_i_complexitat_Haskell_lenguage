--buscarPrimers: retorna només els nombres primers d’una llista d’enters
buscarPrimers :: [Int] -> [Int]
buscarPrimers [] = []
buscarPrimers (x:xs)
  | esPrimer x = x : buscarPrimers xs --Si x és primer, l’afegim i continuem analitzant de manera recursiva
  | otherwise  = buscarPrimers xs --Si no ho és, l’ignorem i continuem analitzant de manera recursiva

esPrimer :: Int -> Bool --Funció auxiliar booleana per determinar si és o no primer
esPrimer n
  | n < 2 = False
  | otherwise = null [d | d <- [2..limit], n `mod` d == 0] --Aquí ens crea una llista de divisors de d i, si no hi ha cap divisor, la llista serà buida, per tant és primer
    where
    limit = floor (sqrt (fromIntegral n)) --fromIntegral converteix un enter en decimal. El floor arrodoneix cap a baix a l'enter més proper. Fem l'arrel de n ja que 9 és divisor de 3, per exemple.

--runLengthEncoding: aplica compressió RLE a una cadena. Per exemple: "aaaabbbcca" → [('a',4),('b',3),('c',2),('a',1)]
runLengthEncoding :: String -> [(Char, Int)] --Funció que dona un string i retorna una tupla de caràcter i enter
runLengthEncoding [] = []
runLengthEncoding (x:xs) = (x, 1 + length iguals) : runLengthEncoding resta --Recursivament aconsegueix tots els caràcters
  where
    iguals = takeWhile (== x) xs --Agafa tots els caràcters consecutius iguals a x
    resta  = dropWhile (== x) xs --Elimina tots els caràcters consecutius iguals a x

