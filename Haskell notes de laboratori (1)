--doblarMap: utilitza map per doblar elements
doblarMap :: Num a => [a] -> [a]
doblarMap = map (*2) --Multiplica cada element per 2

--incrementarMap: utilitza map per incrementar
incrementarMap :: Num a => [a] -> [a]
incrementarMap = map (+1) --Suma 1 a cada element

-- ===========================================================================
-- Exercici 4 (folding)
