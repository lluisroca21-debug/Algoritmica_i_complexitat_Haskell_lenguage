--sumarQuadratsRec: versió recursiva
sumarQuadratsRec :: Num a => [a] -> a
sumarQuadratsRec [] = 0
sumarQuadratsRec (x:xs) = x*x + sumarQuadratsRec xs

--sumarQuadratsMapFold: map + fold combinats
sumarQuadratsMapFold :: Num a => [a] -> a
sumarQuadratsMapFold xs = foldl (+) 0 (map (\x -> x*x) xs) --map suma els quadrats de cada element. el primer () és la funció i el segon () és la llista que se dona. El fold simplement suma tots els elements de l'array d'esquerra a dreta.

